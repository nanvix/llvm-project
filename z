#
# Description
#
#   Project-specific release steps. Builds a Docker image that bundles the
#   freshly installed Nanvix toolchain. The image is tagged
#   "<DOCKER_IMAGE>:latest" and, when invoked from a git checkout, additionally
#   "<DOCKER_IMAGE>:<short-commit-hash>".
#
# Global Variables
#
#   - DOCKER_IMAGE: Docker image repository to tag the built image with.
#   - Z_INSTALL_LOCATION: Directory holding the installed toolchain to bundle.
#   - PROJECT_DIR: Project root, used as the Docker build context.
#
# Return Value
#
#   - On success, this function returns zero.
#   - On failure, this function returns non-zero.
#
# Usage Example
#
#   release_steps && echo "Success" || echo "Failure"
#
release_steps() {
    print_info "Building Docker image '${DOCKER_IMAGE}' for ${Z_PROJECT_NAME}..."

    # Docker is required to build the release image.
    if ! command -v docker >/dev/null 2>&1; then
        print_error "docker is not installed or not in PATH; cannot build the release image."
        return 1
    fi

    # Prepare the Docker build context. The Dockerfile copies the contents of
    # 'docker-install/' into the image's install location, so stage a fresh copy
    # of the installed toolchain there.
    local docker_context="${PROJECT_DIR}/docker-install"
    rm -rf "${docker_context}"
    mkdir -p "${docker_context}" || {
        print_error "Failed to create Docker context directory '${docker_context}'."
        return 1
    }
    # Remove the staged build context when this function returns, regardless of
    # success or failure. Guard the expansion so an inherited RETURN trap (under
    # `set -T`) that fires after docker_context goes out of scope does not abort
    # under `set -u`.
    trap 'rm -rf "${docker_context:-}" 2>/dev/null || true' RETURN
    cp -a "${Z_INSTALL_LOCATION}/." "${docker_context}/" || {
        print_error "Failed to populate Docker context from '${Z_INSTALL_LOCATION}'."
        return 1
    }

    # Always tag 'latest'; add a short commit hash tag when this is a git
    # checkout so released images are traceable to a specific commit.
    local docker_tags=(-t "${DOCKER_IMAGE}:latest")
    local short_sha
    short_sha=$(git -C "${PROJECT_DIR}" rev-parse --short HEAD 2>/dev/null || true)
    if [[ -n "${short_sha}" ]]; then
        docker_tags+=(-t "${DOCKER_IMAGE}:${short_sha}")
    fi

    docker build "${docker_tags[@]}" -f "${PROJECT_DIR}/Dockerfile" "${PROJECT_DIR}" || {
        print_error "Failed to build Docker image."
        return 1
    }

    print_info "Docker image built: ${DOCKER_IMAGE}:latest${short_sha:+ , ${DOCKER_IMAGE}:${short_sha}}"

    return 0
}

#==================================================================================================
# Update Support (inlined from .z/update.sh)
#
# The functions below fetch the latest release information for a Nanvix
# dependency and rewrite the related readonly variables in this z script when
# they are out of date. Two strategies are supported:
#
#   * asset mode (default): selects a release asset by name, parses a version
#     and short commit hash from the asset file name, and updates the
#     <PREFIX>_VERSION, <PREFIX>_SHORT_COMMIT_HASH and <PREFIX>_SHA256_CHECKSUM
#     variables.
#
#   * tag mode (--tag): reads the release tag name (.tag_name) and updates the
#     <PREFIX>_RELEASE_TAG variable, preserving an optional
#     "${Z_<PREFIX>_RELEASE_TAG:-<default>}" environment override.
#==================================================================================================

# Names of the variables modified by the last update operation.
Z_UPDATED_VARS=()
# Whether the last update operation changed this z script.
Z_UPDATE_CHANGED=false
# Release tag resolved by the last tag-mode update operation.
Z_UPDATE_TAG=""

#
# Description
#
#   Updates a plain `readonly VAR="value"` definition in this z script,
#   appending it if absent.
#
# Parameters
#
#   - $1: Variable name.
#   - $2: New value.
#
update_var() {
    local var=$1 val=$2 esc_val line current_val
    esc_val=$(printf '%s' "$val" | sed 's/[\/&]/\\&/g')

    # Find first matching definition (if any).
    line=$(grep -m1 -E "^(readonly[[:space:]]+)?${var}=" "$Z_FILE_PATH" || true)

    if [[ -n "$line" ]]; then
        # Extract RHS, strip comments/whitespace and optional surrounding quotes.
        current_val=$(printf '%s' "$line" | sed -E "s/^[^=]+=//; s/[[:space:]]*#.*$//; s/^[[:space:]]*//; s/[[:space:]]*$//; s/^\"(.*)\"$/\1/; s/^'(.*)'$/\1/")
    else
        current_val=""
    fi

    if [[ "$current_val" == "$val" ]]; then
        print_info "No change for ${var} (already ${val})"
        return 0
    fi

    if [[ -n "$line" ]]; then
        sed -E -i "s|^(readonly[[:space:]]+)?${var}=.*$|readonly ${var}=\"${esc_val}\"|" "$Z_FILE_PATH"
    else
        echo "readonly ${var}=\"${val}\"" >> "$Z_FILE_PATH"
    fi

    Z_UPDATED_VARS+=("$var")
    Z_UPDATE_CHANGED=true
    print_info "Updated ${var} -> ${val}"
}

#
# Description
#
#   Updates a `readonly VAR="${ENV:-default}"` definition in this z script,
#   preserving the environment-override form when present and falling back to a
#   plain assignment otherwise.
#
# Parameters
#
#   - $1: Variable name.
#   - $2: Environment override variable name.
#   - $3: New default value.
#
update_tag_var() {
    local var=$1 envvar=$2 val=$3 esc_val line current_val
    esc_val=$(printf '%s' "$val" | sed 's/[\/&|]/\\&/g')

    line=$(grep -m1 -E "^(readonly[[:space:]]+)?${var}=" "$Z_FILE_PATH" || true)

    if [[ -z "$line" ]]; then
        echo "readonly ${var}=\"\${${envvar}:-${val}}\"" >> "$Z_FILE_PATH"
        Z_UPDATED_VARS+=("$var")
        Z_UPDATE_CHANGED=true
        print_info "Added ${var} -> ${val}"
        return 0
    fi

    if [[ "$line" == *"\${${envvar}:-"* ]]; then
        # Preserve the "${ENV:-default}" override; replace only the default.
        current_val=$(printf '%s' "$line" | sed -E "s/.*\\\$\\{${envvar}:-([^}]*)\\}.*/\1/")
        if [[ "$current_val" == "$val" ]]; then
            print_info "No change for ${var} (already ${val})"
            return 0
        fi
        sed -E -i "s|(\\\$\\{${envvar}:-)[^}]*(\\})|\1${esc_val}\2|" "$Z_FILE_PATH"
    else
        current_val=$(printf '%s' "$line" | sed -E "s/^[^=]+=//; s/[[:space:]]*#.*$//; s/^[[:space:]]*//; s/[[:space:]]*$//; s/^\"(.*)\"$/\1/; s/^'(.*)'$/\1/")
        if [[ "$current_val" == "$val" ]]; then
            print_info "No change for ${var} (already ${val})"
            return 0
        fi
        sed -E -i "s|^(readonly[[:space:]]+)?${var}=.*$|readonly ${var}=\"${esc_val}\"|" "$Z_FILE_PATH"
    fi

    Z_UPDATED_VARS+=("$var")
    Z_UPDATE_CHANGED=true
    print_info "Updated ${var} -> ${val}"
}

#
# Description
#
#   Fetches the latest release metadata from a GitHub API URL and updates the
#   related variables in this z script when they are out of date.
#
# Parameters
#
#   tag mode:   update_release --tag <api_url> <var_prefix>
#   asset mode: update_release <api_url> <asset_regex> <parse_regex> <var_prefix>
#
# Return Value
#
#   - On success, returns zero (even when no update was required).
#   - On failure, returns non-zero.
#
update_release() {
    local mode=asset
    if [[ "${1:-}" == "--tag" ]]; then
        mode=tag
        shift
    fi

    local api asset_regex parse_regex var_prefix
    if [[ "$mode" == "asset" ]]; then
        if [[ "$#" -ne 4 ]]; then
            print_error "update_release (asset mode) requires <api_url> <asset_regex> <parse_regex> <var_prefix>"
            return 1
        fi
        api=$1
        asset_regex=$2
        parse_regex=$3
        var_prefix=$4
    else
        if [[ "$#" -ne 2 ]]; then
            print_error "update_release (tag mode) requires <api_url> <var_prefix>"
            return 1
        fi
        api=$1
        var_prefix=$2
        asset_regex=""
        parse_regex=""
    fi

    # Validate prefix as a shell variable name.
    if ! [[ $var_prefix =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
        print_error "Variable prefix '${var_prefix}' is not a valid shell identifier"
        return 1
    fi

    if ! command -v jq >/dev/null 2>&1; then
        print_error "jq is not installed and is required by the update command"
        return 1
    fi
    if ! command -v curl >/dev/null 2>&1; then
        print_error "curl is not installed and is required by the update command"
        return 1
    fi

    local version_var="${var_prefix}_VERSION"
    local short_hash_var="${var_prefix}_SHORT_COMMIT_HASH"
    local checksum_var="${var_prefix}_SHA256_CHECKSUM"
    local tag_var="${var_prefix}_RELEASE_TAG"
    local tag_env_var="Z_${var_prefix}_RELEASE_TAG"

    print_info "Fetching release metadata: ${api}"
    local resp
    resp=$(curl -sL "$api" || true)
    if [[ -z "$resp" ]]; then
        print_error "Empty response from API"
        return 1
    fi

    # ----------------------------------------------------------------------
    # Tag mode: pin <PREFIX>_RELEASE_TAG to the release's tag_name.
    # ----------------------------------------------------------------------
    if [[ "$mode" == "tag" ]]; then
        local tag
        tag=$(echo "$resp" | jq -r '.tag_name // empty')
        if [[ -z "$tag" ]]; then
            print_error "Release metadata has no tag_name"
            return 1
        fi
        print_info "Latest release tag: ${tag}"
        Z_UPDATE_TAG="$tag"
        update_tag_var "$tag_var" "$tag_env_var" "$tag"
        return 0
    fi

    # ----------------------------------------------------------------------
    # Asset mode: select an asset and update version/hash/checksum variables.
    # ----------------------------------------------------------------------
    local asset
    asset=$(echo "$resp" | jq -r --arg rx "$asset_regex" '.assets[] | select(.name | test($rx))' || true)
    if [[ -z "$asset" ]]; then
        print_info "No matching asset found (regex: ${asset_regex})"
        return 0
    fi

    local asset_name asset_digest version short_hash
    asset_name=$(echo "$asset" | jq -r '.name')
    asset_digest=$(echo "$asset" | jq -r '.digest // empty')

    if [[ "$asset_name" =~ $parse_regex ]]; then
        version=${BASH_REMATCH[1]}
        short_hash=${BASH_REMATCH[2]}
    else
        print_error "Failed to parse version/hash from asset name using regex: ${parse_regex}"
        return 1
    fi

    print_info "Latest release parsed: version=${version} short_hash=${short_hash}"

    update_var "$short_hash_var" "$short_hash"
    update_var "$checksum_var" "$asset_digest"
    update_var "$version_var" "$version"

    return 0
}

#
# Description
#
#   Executes project-specific steps for updating pinned dependency versions.
#
# Return Value
#
#   - On success, this function returns zero.
#   - On failure, this function returns non-zero.
#
update_steps() {
    # Reset update tracking state.
    Z_UPDATED_VARS=()
    Z_UPDATE_CHANGED=false
    Z_UPDATE_TAG=""

    # Nanvix release: pin NANVIX_RELEASE_TAG to the latest nanvix/nanvix tag.
    update_release --tag \
        "https://api.github.com/repos/nanvix/nanvix/releases/latest" \
        "NANVIX" || {
        print_error "Failed to update NANVIX_RELEASE_TAG."
        return 1
    }

    if [[ "${Z_UPDATE_CHANGED}" == "true" ]]; then
        print_info "Updated variables: ${Z_UPDATED_VARS[*]}"
    else
        print_info "All dependencies are already up to date."
    fi

    # When running under GitHub Actions, expose the result so the workflow can
    # decide whether to open a pull request without re-deriving it.
    if [[ -n "${GITHUB_OUTPUT:-}" ]]; then
        {
            echo "changed=${Z_UPDATE_CHANGED}"
            echo "tag=${Z_UPDATE_TAG}"
            echo "updated_vars=$(IFS=,; echo "${Z_UPDATED_VARS[*]:-}")"
        } >> "${GITHUB_OUTPUT}"
    fi

    return 0
}

#==================================================================================================
# Test Support
#
# Build-only smoke tests for the produced toolchain. These do not run any
# program; they verify that the expected runtime artifacts are installed and
# that minimal C and C++ programs compile and link for the Nanvix target.
#==================================================================================================

#
# Description
#
#   Verifies that the expected stage 1 runtime artifacts are present in the
#   install location.
#
# Return Value
#
#   - On success, returns zero.
#   - On failure, returns non-zero.
#
# Usage Example
#
#   ./z verify
#
verify_artifacts() {
    local install_location="${Z_INSTALL_LOCATION:-${DEFAULT_INSTALL_LOCATION}}"

    print_info "Verifying toolchain artifacts in '${install_location}'..."
    local failed=0

    # C++ runtime libraries.
    for lib in libc++.a libc++abi.a libunwind.a; do
        if [[ ! -f "${install_location}/lib/${lib}" ]]; then
            print_error "Missing runtime library '${install_location}/lib/${lib}'."
            failed=1
        fi
    done

    # compiler-rt builtins (per-target directory).
    local builtins
    builtins=$(find "${install_location}/lib/clang" \
        -path "*/${NANVIX_TARGET}/libclang_rt.builtins*.a" 2>/dev/null | head -1)
    if [[ -z "${builtins}" ]]; then
        print_error "compiler-rt builtins library for ${NANVIX_TARGET} not found."
        failed=1
    fi

    if [[ "${failed}" -ne 0 ]]; then
        print_error "Artifact verification failed."
        return 1
    fi

    print_success "All expected toolchain artifacts are present."
    return 0
}

#
# Description
#
#   Compiles and links one smoke-test source for the Nanvix target without
#   running it.
#
# Parameters
#
#   - $1: Compiler to use ('clang' or 'clang++').
#   - $2: Path to the source file.
#   - $3: Path to the output executable.
#
# Return Value
#
#   - On success, returns zero.
#   - On failure, returns non-zero.
#
_build_one_smoke_test() {
    local compiler="$1"
    local source="$2"
    local output="$3"
    local install_location="${Z_INSTALL_LOCATION:-${DEFAULT_INSTALL_LOCATION}}"
    local sysroot_location="${Z_SYSROOT_LOCATION:-${install_location}}"

    # The Nanvix user linker script provides the section bounds (e.g.
    # __eh_frame_start, __init_array_start) that crt0/libunwind reference.
    local linker_script="${sysroot_location}/lib/user.ld"
    if [[ ! -f "${linker_script}" ]]; then
        print_error "Nanvix linker script not found at '${linker_script}'."
        return 1
    fi

    # NOTE: --allow-multiple-definition works around a known overlap in the
    # Nanvix release artifacts, where crt0.o and libc.a both define the
    # __kcall_* / fork_* startup stubs. This is a packaging detail of the
    # nanvix/nanvix release, not a toolchain issue; drop the flag once the
    # release no longer ships the duplicated symbols.
    print_info "Building $(basename "${source}") -> $(basename "${output}")..."
    "${install_location}/bin/${compiler}" \
        --target="${NANVIX_TARGET}" \
        --sysroot="${sysroot_location}" \
        -Wl,--allow-multiple-definition \
        -T "${linker_script}" \
        "${source}" \
        -o "${output}" || {
        print_error "Failed to build '${source}'."
        return 1
    }

    return 0
}

#
# Description
#
#   Build-only smoke test: compiles and links the C and C++ smoke-test programs
#   using the installed toolchain for the Nanvix target. Does not run them.
#
# Return Value
#
#   - On success, returns zero.
#   - On failure, returns non-zero.
#
# Usage Example
#
#   ./z test
#
test_build() {
    local install_location="${Z_INSTALL_LOCATION:-${DEFAULT_INSTALL_LOCATION}}"

    for compiler in clang clang++; do
        if [[ ! -x "${install_location}/bin/${compiler}" ]]; then
            print_error "'${install_location}/bin/${compiler}' not found. Build and install the toolchain first."
            return 1
        fi
    done

    local out_dir="${PROJECT_DIR}/build/tests/smoke"
    mkdir -p "${out_dir}" || {
        print_error "Failed to create smoke-test output directory '${out_dir}'."
        return 1
    }

    _build_one_smoke_test clang   "${PROJECT_DIR}/tests/smoke/hello.c"   "${out_dir}/hello_c.elf"   || return 1
    _build_one_smoke_test clang++ "${PROJECT_DIR}/tests/smoke/hello.cpp" "${out_dir}/hello_cpp.elf" || return 1

    print_success "Smoke tests built successfully for ${NANVIX_TARGET}."
    return 0
}

#==================================================================================================
# Main Script
#==================================================================================================

# Intercept the project-specific 'verify' and 'test' commands before delegating
# to the z framework, whose command set is fixed. These build-only tests run
# independently of the standard configure/build/install pipeline and do not
# appear in './z help'.
case "${1:-}" in
    verify)
        _load_project_config 2>/dev/null || true
        verify_artifacts || exit 1
        exit 0
        ;;
    test)
        _load_project_config 2>/dev/null || true
        test_build || exit 1
        exit 0
        ;;
esac

# Run main function with all arguments
zmain "$@" || {
    exit 1
}

exit 0
